{% include "common/file_header.j2" with context %}

package {{ api_operation.package_name }}

{% if api_operation.imports %}
import (
{% for import in api_operation.imports %}
{% if import %}
	"{{ import }}"
{% else %}

{% endif %}
{% endfor %}
)
{% endif %}

// {{ api_operation.client_struct.name }} - {{ api_operation.tag }} operations
type {{ api_operation.client_struct.name }} struct {
	rootSDK          hooks.SDK
	sdkConfiguration config.SDKConfiguration
	hooks            *hooks.Hooks
}

// New{{ api_operation.client_struct.name }} creates a new {{ api_operation.client_struct.name }} client
func New{{ api_operation.client_struct.name }}(rootSDK hooks.SDK, sdkConfig config.SDKConfiguration, hooks *hooks.Hooks) *{{ api_operation.client_struct.name }} {
	return &{{ api_operation.client_struct.name }}{
		rootSDK:          rootSDK,
		sdkConfiguration: sdkConfig,
		hooks:            hooks,
	}
}

{% for method in api_operation.methods %}
{% if method.description %}
// {{ method.name }} - {{ method.description }}
{% else %}
// {{ method.name }} - {{ method.http_method }} {{ method.path }}
{% endif %}
func (s *{{ api_operation.client_struct.name }}) {{ method.name }}(
	ctx context.Context{% if method.path_params %}{% for param in method.path_params %},
	path{{ param.param_name }} {{ param.go_type }}{% endfor %}{% endif %}{% if method.query_params %}{% for param in method.query_params %},
	query{{ param.param_name }} {{ param.go_type }}{% endfor %}{% endif %}{% if method.header_params %}{% for param in method.header_params %},
	header{{ param.param_name }} {{ param.go_type }}{% endfor %}{% endif %}{% if method.has_request_body %},
	request components.{{ method.request_body_type }}{% endif %},
	opts ...operations.Option,
) (*operations.{{ method.name }}Response, error) {
	o := operations.Options{}
	supportedOptions := []string{
		operations.SupportedOptionRetries,
		operations.SupportedOptionTimeout,
	}

	for _, opt := range opts {
		if err := opt(&o, supportedOptions...); err != nil {
			return nil, fmt.Errorf("error applying option: %w", err)
		}
	}

	var baseURL string
	if o.ServerURL == nil {
		baseURL, _ = s.sdkConfiguration.GetServerDetails()
	} else {
		baseURL = *o.ServerURL
	}
	opURL, err := url.JoinPath(baseURL, "{{ method.path }}")
	if err != nil {
		return nil, fmt.Errorf("error generating URL: %w", err)
	}

	{% if method.path_params %}
	// Build path parameters
	pathParams := map[string]string{
	{% for param in method.path_params %}
		"{{ param.original_name }}": fmt.Sprintf("%v", path{{ param.param_name }}),
	{% endfor %}
	}
	opURL = utils.ReplaceParameters(opURL, pathParams)
	{% endif %}

	hookCtx := hooks.HookContext{
		SDK:              s.rootSDK,
		SDKConfiguration: s.sdkConfiguration,
		BaseURL:          baseURL,
		Context:          ctx,
		OperationID:      "{{ method.operation_id }}",
		OAuth2Scopes:     nil,
		SecuritySource:   nil,
	}

	{% if method.has_request_body %}
	bodyReader, reqContentType, err := utils.SerializeRequestBody(ctx, request, false, false, "Request", "json", `request:"mediaType={{ method.request_body_content_type }}"`)
	if err != nil {
		return nil, err
	}
	{% else %}
	var bodyReader io.Reader = nil
	var reqContentType string = ""
	{% endif %}

	timeout := o.Timeout
	if timeout == nil {
		timeout = s.sdkConfiguration.Timeout
	}

	if timeout != nil {
		var cancel context.CancelFunc
		ctx, cancel = context.WithTimeout(ctx, *timeout)
		defer cancel()
	}

	req, err := http.NewRequestWithContext(ctx, "{{ method.http_method }}", opURL, bodyReader)
	if err != nil {
		return nil, fmt.Errorf("error creating request: %w", err)
	}
	req.Header.Set("Accept", "application/json")
	req.Header.Set("User-Agent", s.sdkConfiguration.UserAgent)
	if reqContentType != "" {
		req.Header.Set("Content-Type", reqContentType)
	}

	{% if method.query_params %}
	// Build query parameters
	queryParams := struct {
	{% for param in method.query_params %}
		{{ param.param_name }} {{ param.go_type }} `queryParam:"name={{ param.original_name }},style=form,explode=true"`
	{% endfor %}
	}{
	{% for param in method.query_params %}
		{{ param.param_name }}: query{{ param.param_name }},
	{% endfor %}
	}
	if err := utils.PopulateQueryParams(ctx, req, queryParams, nil); err != nil {
		return nil, err
	}
	{% endif %}

	{% if method.header_params %}
	// Build header parameters
	headerParams := struct {
	{% for param in method.header_params %}
		{{ param.param_name }} {{ param.go_type }} `header:"name={{ param.original_name }},style=simple,explode=false"`
	{% endfor %}
	}{
	{% for param in method.header_params %}
		{{ param.param_name }}: header{{ param.param_name }},
	{% endfor %}
	}
	utils.PopulateHeaders(ctx, req, headerParams, nil)
	{% endif %}

	for k, v := range o.SetHeaders {
		req.Header.Set(k, v)
	}

	globalRetryConfig := s.sdkConfiguration.RetryConfig
	retryConfig := o.Retries
	if retryConfig == nil {
		retryConfig = globalRetryConfig
	}

	httpRes, err := utils.Retry(ctx, utils.Retries{
		Config:      retryConfig,
		StatusCodes: []string{"5XX"},
	}, func() (*http.Response, error) {
		if req.Body != nil {
			copyBody, err := req.GetBody()
			if err != nil {
				return nil, err
			}
			req.Body = copyBody
		}

		req, err = s.hooks.BeforeRequest(hooks.BeforeRequestContext{HookContext: hookCtx}, req)
		if err != nil {
			return nil, err
		}

		httpRes, err := s.sdkConfiguration.Client.Do(req)
		if err != nil || httpRes == nil {
			if err != nil {
				hookCtx := hooks.AfterErrorContext{HookContext: hookCtx}
				httpRes, err = s.hooks.AfterError(hookCtx, httpRes, err)
			}
			return httpRes, err
		}

		httpRes, err = s.hooks.AfterSuccess(hooks.AfterSuccessContext{HookContext: hookCtx}, httpRes)
		if err != nil {
			return httpRes, err
		}

		return httpRes, nil
	})
	if err != nil {
		return nil, err
	}

	defer httpRes.Body.Close()

	res := &operations.{{ method.name }}Response{
		HTTPMeta: components.HTTPMetadata{
			Response: httpRes,
		},
	}

	switch {
	case utils.MatchStatusCodes([]string{"200"}, httpRes.StatusCode):
		// TODO: Parse response body based on content type
	default:
		rawBody, err := utils.ConsumeRawBody(httpRes)
		if err != nil {
			return nil, err
		}
		httpRes.Body.Close()
		return nil, fmt.Errorf("error: status code %d, body: %s", httpRes.StatusCode, string(rawBody))
	}

	return res, nil
}

{% endfor %}
