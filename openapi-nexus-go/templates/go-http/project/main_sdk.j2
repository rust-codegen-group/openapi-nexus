{% include "common/file_header.j2" with context %}

package {{ main_sdk.package_name }}

import (
	"net/http"

	"{{ module_path }}/internal/config"
	"{{ module_path }}/internal/hooks"
	"{{ module_path }}/apis"
)

// {{ main_sdk.sdk_name }}SDK is the main SDK struct
type {{ main_sdk.sdk_name }}SDK struct {
	sdkConfiguration config.SDKConfiguration
	hooks            *hooks.Hooks
{% for sub_client in main_sdk.sub_clients %}
	{{ sub_client.name }} *apis.{{ sub_client.type_name }}
{% endfor %}
}

// Ensure {{ main_sdk.sdk_name }}SDK implements hooks.SDK interface
var _ hooks.SDK = (*{{ main_sdk.sdk_name }}SDK)(nil)

// New creates a new instance of {{ main_sdk.sdk_name }}SDK
func New(opts ...SdkOption) (*{{ main_sdk.sdk_name }}SDK, error) {
	sdkConfig := config.NewSDKConfiguration()
	h := hooks.New()

	// Apply options
	for _, opt := range opts {
		if err := opt(&sdkConfig); err != nil {
			return nil, err
		}
	}

	// Initialize hooks
	sdkConfig = h.SDKInit(sdkConfig)

	sdk := &{{ main_sdk.sdk_name }}SDK{
		sdkConfiguration: sdkConfig,
		hooks:            h,
	}

	// Initialize sub-clients
{% for sub_client in main_sdk.sub_clients %}
	sdk.{{ sub_client.name }} = apis.New{{ sub_client.type_name }}(sdk, sdkConfig, h)
{% endfor %}

	return sdk, nil
}

// SdkOption is a function that configures the SDK
type SdkOption func(*config.SDKConfiguration) error

// WithBaseURL sets the base URL for the SDK
func WithBaseURL(baseURL string) SdkOption {
	return func(cfg *config.SDKConfiguration) error {
		return cfg.SetServerURL(baseURL)
	}
}

// WithHTTPClient sets a custom HTTP client for the SDK
func WithHTTPClient(client *http.Client) SdkOption {
	return func(cfg *config.SDKConfiguration) error {
		cfg.SetClient(client)
		return nil
	}
}
