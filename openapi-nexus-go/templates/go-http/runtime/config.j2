package config

import (
	"net/http"
	"time"

	"{{ module_path }}/runtime/retry"
)

type HTTPClient interface {
	Do(req *http.Request) (*http.Response, error)
}

type SDKConfiguration struct {
	Client HTTPClient

	ServerURL   string
	UserAgent   string
	RetryConfig *retry.Config
	Timeout     *time.Duration
}

func (c *SDKConfiguration) GetServerDetails() (string, map[string]string) {
	return c.ServerURL, map[string]string{}
}

// NewSDKConfiguration creates a new SDK configuration with default values
func NewSDKConfiguration() SDKConfiguration {
	return SDKConfiguration{
		Client:    http.DefaultClient,
		ServerURL: "",
		UserAgent: "openapi-nexus",
		Timeout:   nil,
	}
}

// SetServerURL sets the server URL for the SDK
func (c *SDKConfiguration) SetServerURL(url string) error {
	c.ServerURL = url
	return nil
}

// SetClient sets a custom HTTP client for the SDK
func (c *SDKConfiguration) SetClient(client *http.Client) {
	c.Client = client
}
