[package]
name = "inline-object-test"
version = "0.1.0"
edition = "2024"
description = "Test case for inline objects (not arrays) with snake_case to camelCase conversion"

[dependencies]
ureq = { version = "3", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.6"
serde_repr = "0.1"
