[package]
name = "primitive-array-test"
version = "0.1.0"
edition = "2024"
description = "Test case for arrays with primitive items (should not be affected by recursive parsing)"

[dependencies]
ureq = { version = "3", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
