[package]
name = "multiple-discriminated-unions-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture with multiple discriminated unions to verify Kind types"

[dependencies]
ureq = { version = "3", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
