[package]
name = "mixed-property-types-test"
version = "0.1.0"
edition = "2024"
description = "Test case for object with mix of simple types, arrays, references, and inline objects"

[dependencies]
ureq = { version = "3", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
