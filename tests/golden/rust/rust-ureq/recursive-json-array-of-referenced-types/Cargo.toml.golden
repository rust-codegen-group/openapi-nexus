[package]
name = "array-of-referenced-types-test"
version = "0.1.0"
edition = "2024"
description = "Test case for array of referenced model types with recursive FromJSON calls"

[dependencies]
ureq = { version = "3", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
