[package]
name = "complex-array-structure-test"
version = "0.1.0"
edition = "2024"
description = "Test case for array of inline objects where each object has nested inline objects"

[dependencies]
ureq = { version = "3", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
