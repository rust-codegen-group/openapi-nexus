[package]
name = "union-type-with-primitives-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture for union types with primitive members"

[dependencies]
aioduct = { version = "0.1.8", features = ["tokio", "rustls", "rustls-ring", "json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
