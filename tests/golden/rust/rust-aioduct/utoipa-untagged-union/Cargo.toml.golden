[package]
name = "utoipa-untagged-union-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture for untagged union manual utoipa impl generation"

[dependencies]
aioduct = { version = "0.2", features = ["tokio", "rustls", "rustls-ring", "json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
utoipa = { version = "5" }
