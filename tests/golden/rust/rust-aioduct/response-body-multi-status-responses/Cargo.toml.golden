[package]
name = "multi-status-api"
version = "0.1.0"
edition = "2024"
description = "Generated Rust SDK."

[dependencies]
aioduct = { version = "0.1.3", features = ["tokio", "rustls", "json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
tokio = { version = "1", features = ["full"] }
