[package]
name = "multiline-docs"
version = "0.1.0"
edition = "2024"
description = "A test fixture for multi-line doc comments"

[dependencies]
aioduct = { version = "0.1.6", features = ["tokio", "rustls", "rustls-ring", "json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
