[package]
name = "utoipa-mixed-types-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture covering all schema kinds with utoipa enabled"

[dependencies]
aioduct = { version = "0.1.8", features = ["tokio", "rustls", "rustls-ring", "json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
url = "2"
utoipa = { version = "5" }
