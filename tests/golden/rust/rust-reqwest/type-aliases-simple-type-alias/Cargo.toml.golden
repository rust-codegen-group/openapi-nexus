[package]
name = "simple-type-alias-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture for simple type aliases (not unions or intersections)"

[dependencies]
reqwest = { version = "0.12", features = ["json", "multipart"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
