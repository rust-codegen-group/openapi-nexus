[package]
name = "petstore-api"
version = "0.1.0"
edition = "2024"
description = "This is a sample Pet Store Server based on the OpenAPI 3.1 specification"

[dependencies]
reqwest = { version = "0.12", features = ["json", "multipart"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
url = "2"
