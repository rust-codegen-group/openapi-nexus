[package]
name = "request-body-content-types"
version = "0.1.0"
edition = "2024"
description = "Covers non-JSON request body media types to pin Content-Type emission."

[dependencies]
reqwest = { version = "0.12", features = ["json", "multipart"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
