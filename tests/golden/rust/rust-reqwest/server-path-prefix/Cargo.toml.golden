[package]
name = "server-path-prefix-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture for server URL path prefix stripping in operation paths."

[dependencies]
reqwest = { version = "0.12", features = ["json", "multipart"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.6"
serde_repr = "0.1"
