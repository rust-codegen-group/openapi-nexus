[package]
name = "naming-conventions-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture to verify language property naming conventions"

[dependencies]
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
tokio = { version = "1", features = ["full"] }
url = "2"
