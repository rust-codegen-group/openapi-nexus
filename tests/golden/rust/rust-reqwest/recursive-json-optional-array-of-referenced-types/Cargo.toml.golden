[package]
name = "optional-array-of-referenced-types-test"
version = "0.1.0"
edition = "2024"
description = "Test case for optional array of referenced model types"

[dependencies]
reqwest = { version = "0.12", features = ["json", "multipart"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.6"
serde_repr = "0.1"
