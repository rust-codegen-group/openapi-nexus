[package]
name = "intersection-type-all-of-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture for allOf intersection types"

[dependencies]
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tokio = { version = "1", features = ["full"] }
