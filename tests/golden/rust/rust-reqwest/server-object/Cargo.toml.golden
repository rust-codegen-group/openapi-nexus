[package]
name = "test-api-with-server-objects"
version = "0.1.0"
edition = "2024"
description = "This is a test API specification that includes various server configurations"

[dependencies]
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
