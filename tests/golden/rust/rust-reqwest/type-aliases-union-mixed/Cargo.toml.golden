[package]
name = "union-type-with-mixed-members-test"
version = "0.1.0"
edition = "2024"
description = "Test fixture for union types with both interfaces and primitives"

[dependencies]
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
