[package]
name = "comprehensive-schema-types-example"
version = "0.1.0"
edition = "2024"
description = "Comprehensive test for all OpenAPI v3.1.2 schema types"

[dependencies]
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tokio = { version = "1", features = ["full"] }
