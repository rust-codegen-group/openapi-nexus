[package]
name = "comprehensive-schema-types-example"
version = "0.1.0"
edition = "2024"
description = "Comprehensive test for all OpenAPI v3.1.2 schema types"

[dependencies]
reqwest = { version = "0.12", features = ["json", "multipart"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde-xml-rs = "0.8.2"
serde_repr = "0.1"
