[package]
name = "array-with-reference-property-test"
version = "0.1.0"
edition = "2024"
description = "Test case for array of inline objects that contain a reference property"

[dependencies]
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_repr = "0.1"
