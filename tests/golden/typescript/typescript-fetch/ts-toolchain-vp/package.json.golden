{
  "description": "Test fixture for discriminated union where variants are references to component schemas.\nThis is similar to the ContainerImage pattern in the infiron API.\n",
  "devDependencies": {
    "typescript": "latest",
    "vite-plus": "latest"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "openapi",
    "api-client",
    "typescript",
    "generated"
  ],
  "main": "./dist/index.mjs",
  "name": "discriminated-union-with-references-test",
  "scripts": {
    "build": "vp pack",
    "check": "vp check --no-fmt"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "1.0.0"
}