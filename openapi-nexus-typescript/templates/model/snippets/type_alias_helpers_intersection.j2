{# Intersection type (allOf) - generate FromJSON/ToJSON with proper conversion for each member #}
export function {{ model_type_alias.type_alias_definition.ts_name }}FromJSON(json: any): {{ model_type_alias.type_alias_definition.ts_name }} {
  return {{ model_type_alias.type_alias_definition.ts_name }}FromJSONTyped(json, false);
}

export function {{ model_type_alias.type_alias_definition.ts_name }}FromJSONTyped(json: any, ignoreDiscriminator: boolean): {{ model_type_alias.type_alias_definition.ts_name }} {
  if (json == null) {
    return json;
  }
  return {
{% for member in model_type_alias.intersection_members %}
  {% if member.is_reference %}
    ...{{ member.ts_name }}FromJSONTyped(json, ignoreDiscriminator),
  {% endif %}
{% endfor %}
{% for member in model_type_alias.intersection_members %}
  {% if member.is_object and member.object_properties %}
    {% for prop in member.object_properties %}
    {% if prop.nullable_reference_name %}
    '{{ prop.ts_name }}': json['{{ prop.original_name }}'] == null ? null : {{ prop.nullable_reference_name }}FromJSON(json['{{ prop.original_name }}']),
    {% elif prop.reference_name %}
    '{{ prop.ts_name }}': {{ prop.reference_name }}FromJSON(json['{{ prop.original_name }}']),
    {% else %}
    '{{ prop.ts_name }}': json['{{ prop.original_name }}'],
    {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}
  };
}

export function {{ model_type_alias.type_alias_definition.ts_name }}ToJSON(value?: {{ model_type_alias.type_alias_definition.ts_name }} | null): any {
  return {{ model_type_alias.type_alias_definition.ts_name }}ToJSONTyped(value, false);
}

export function {{ model_type_alias.type_alias_definition.ts_name }}ToJSONTyped(value?: {{ model_type_alias.type_alias_definition.ts_name }} | null, ignoreDiscriminator: boolean = false): any {
  if (value == null) {
    return value;
  }
  return {
{# First, generate spread operators for reference members #}
{% for member in model_type_alias.intersection_members %}
  {% if member.is_reference %}
    ...{{ member.ts_name }}ToJSONTyped(value, ignoreDiscriminator),
  {% endif %}
{% endfor %}
{# Then, generate explicit properties from object members #}
{% for member in model_type_alias.intersection_members %}
  {% if member.is_object and member.object_properties %}
    {% for prop in member.object_properties %}
    {% if prop.nullable_reference_name %}
    '{{ prop.original_name }}': value['{{ prop.ts_name }}'] == null ? null : {{ prop.nullable_reference_name }}ToJSON(value['{{ prop.ts_name }}']),
    {% elif prop.reference_name %}
    '{{ prop.original_name }}': {{ prop.reference_name }}ToJSON(value['{{ prop.ts_name }}']),
    {% else %}
    '{{ prop.original_name }}': value['{{ prop.ts_name }}'],
    {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}
  };
}
