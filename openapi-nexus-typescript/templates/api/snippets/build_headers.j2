{% set data = method_data.http_params %}
// Build headers
const headerParameters: Record<string, string> = {
  {% if data.body_param %}
  'Content-Type': 'application/json',
  {% endif %}
  ...this.configuration?.headers,
};

// Add header parameters
{% for param in data.header_params %}
if (requestParameters['{{ param.name }}'] !== undefined) {
  headerParameters['{{ param.name }}'] = String(requestParameters['{{ param.name }}']);
}
{% endfor %}
