{% set data = method_data.http_params %}
// Build path with path parameters
{% if data.path_params %}
let urlPath = `{{ data.http_path }}`;
{% for param in data.path_params %}
urlPath = urlPath.replace(`{${ '{{ param.original_name }}' }}`, encodeURIComponent(String(requestParameters['{{ param.param_name }}'])));
{% endfor %}
{% else %}
let urlPath = `{{ data.http_path }}`;
{% endif %}
